# Copy to .env and adjust as needed (docker compose reads .env automatically).

# Bind published ports to this host IP (use 0.0.0.0 to expose on the LAN).
HOST_IP=127.0.0.1

# firecrest-v2 checkout used to build the API image (up.sh clones it here).
FIRECREST_V2_DIR=./.firecrest-v2

# FireCREST Web UI image. If the pull fails, build from a checkout instead:
#   docker build -t firecrest-ui:local -f deploy/docker/Dockerfile /path/to/firecrest-ui
#   FIRECREST_UI_IMAGE=firecrest-ui:local
FIRECREST_UI_IMAGE=ghcr.io/eth-cscs/firecrest-ui:latest

# UI session secrets (dev only).
SESSION_SECRET=dev-session-secret
SESSION_FILE_SECRET=dev-file-secret
